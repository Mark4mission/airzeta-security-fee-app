rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'hq_admin';
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ─── Users Collection ───────────────────────────────────────
    // All signed-in users can read (needed for admin checks, user lists)
    // Users can create their own profile; update/delete by owner or admin
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId);
      allow update, delete: if isAdmin() || isOwner(userId);
    }

    // ─── Branch Codes ───────────────────────────────────────────
    match /branchCodes/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── Security Costs ─────────────────────────────────────────
    match /securityCosts/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // ─── Bulletin Posts + Comments ──────────────────────────────
    match /bulletinPosts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isAdmin() || 
          (isSignedIn() && resource.data.authorUid == request.auth.uid);
      }
    }

    // ─── Security Levels ────────────────────────────────────────
    match /securityLevels/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // ─── Security Policies (legacy collection name) ─────────────
    match /securityPolicies/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── System Config (Security Policy content) ────────────────
    // Used by SecurityPolicyPage for systemConfig/securityPolicy doc
    match /systemConfig/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── Important Links ────────────────────────────────────────
    match /importantLinks/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── Document Library ───────────────────────────────────────
    match /documentLibrary/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // ─── Security Audit Schedules ───────────────────────────────
    match /securityAuditSchedules/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── Settings (App Settings, Audit Settings) ────────────────
    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── Exchange Rates (monthly rate tables) ───────────────────
    match /exchangeRates/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── Contracts (branch contract files with chunk storage) ───
    match /contracts/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();

      // Chunk sub-collection for large file storage
      match /chunks/{chunkId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn();
        allow delete: if isAdmin();
      }
    }

    // ─── Attachments (monthly attachment files with chunk storage)
    match /attachments/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();

      // Chunk sub-collection for large file storage
      match /chunks/{chunkId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn();
        allow delete: if isAdmin();
      }
    }

    // ─── Security Audit Log ─────────────────────────────────────
    // Signed-in users can create log entries; only admins can read
    // Logs are immutable (no update/delete)
    match /securityAuditLog/{logId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
      allow update, delete: if false; // Immutable logs
    }

    // ─── User Security Metadata ─────────────────────────────────
    // Owner can read/write their own; admin can read all
    match /userSecurity/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow write: if isSignedIn() && isOwner(userId);
    }

    // ─── Reports ────────────────────────────────────────────────
    match /reports/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── Security News ──────────────────────────────────────────
    match /securityNews/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── Audit Schedule Files (per-schedule attachments with chunks)
    match /auditScheduleFiles/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();

      match /chunks/{chunkId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn();
        allow delete: if isAdmin();
      }
    }

    // ─── Deny all other paths ───────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
